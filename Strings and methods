public class Demo2 {

	public static void main(String[] args) {
		/* String s1="Sita"; it is stored in string constant pool.
		It is stored in heap memory*/ 
		/*String s3=new String("Sita"); It is stored in heap memory 
		it is stored in string constant pool */
		/* Difference between ==:comparing memory addresses and 
		 .equals: comparing values*/
		String s1="Sita m";
		String s2="ram";
		String s3=new String("Sita");
		String s4=new String("sita");
		System.out.println(s1==s2); //
		System.out.println(s3.equals(s4));//  
		System.out.println(s1==s3);
		System.out.println(s2.charAt(0));//letter comes from 0th index
		System.out.println(s2.toUpperCase());//changed to uppercase
		System.out.println(s1.toLowerCase());//change to lowercase
		System.out.println(s1.equalsIgnoreCase(s4));//equals are ignored
		System.out.println(s1.startsWith("py"));//check the string start with
		System.out.println(s2.endsWith("m"));//check the string with
		System.out.println(s1.replace("Sita", "Aishu"));//replace of two string
		System.out.println(s2.lastIndexOf("s"));//last index of a string
		System.out.println(s1.trim());
		System.out.println(s2.contains(s4));
	}
